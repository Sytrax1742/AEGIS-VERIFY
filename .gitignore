# Root workspace ignores

# Node / Next.js
/node_modules
/frontend/node_modules
/frontend/.next
/.next
/out
/build

# Python / backend
/backend/venv
/backend/.venv
/backend/__pycache__
/backend/**/*.pyc
/backend/**/*.pyo
/backend/**/*.pyd
/__pycache__
*.pyc
*.pyo
*.pyd

# Environment and secrets
.env
.env.*
/frontend/.env
/frontend/.env.*
/backend/.env
/backend/.env.*

# Logs and local state
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.swp
.DS_Store
.vercel
*.tsbuildinfo

# Documentation and snapshots
logs.md
current_code.md
context.md
